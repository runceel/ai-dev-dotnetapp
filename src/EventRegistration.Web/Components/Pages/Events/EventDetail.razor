@page "/events/{Id:guid}"
@inject EventRegistration.Events.Application.IEventsAppService EventsAppService

<PageTitle>イベント詳細</PageTitle>

@if (_loading)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_event is null)
{
    <MudAlert Severity="Severity.Warning">指定されたイベントが見つかりません。</MudAlert>
    <MudButton Variant="Variant.Text" Href="/events" Class="mt-2">イベント一覧へ戻る</MudButton>
}
else
{
    <MudText Typo="Typo.h4" Class="mb-4">@_event.Name</MudText>

    <MudButton Variant="Variant.Text"
               StartIcon="@Icons.Material.Filled.ArrowBack"
               Href="/events"
               Class="mb-4">
        イベント一覧へ戻る
    </MudButton>

    <MudGrid>
        <MudItem xs="12" md="8">
            <MudCard Class="pa-4">
                <MudCardContent>
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudText Typo="Typo.caption" Color="Color.Primary">開催日時</MudText>
                            <MudText Typo="Typo.body1">@_event.ScheduledAt.ToString("yyyy/MM/dd HH:mm")</MudText>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudText Typo="Typo.caption" Color="Color.Primary">定員</MudText>
                            <MudText Typo="Typo.body1">@_event.Capacity 名</MudText>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudText Typo="Typo.caption" Color="Color.Primary">残り枠数</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                ※ Registrations モジュール実装後に表示
                            </MudText>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudText Typo="Typo.caption" Color="Color.Primary">作成日時</MudText>
                            <MudText Typo="Typo.body1">@_event.CreatedAt.ToString("yyyy/MM/dd HH:mm")</MudText>
                        </MudItem>
                    </MudGrid>

                    @if (!string.IsNullOrEmpty(_event.Description))
                    {
                        <MudDivider Class="my-4" />
                        <MudText Typo="Typo.caption" Color="Color.Primary">説明</MudText>
                        <MudText Typo="Typo.body1" Class="mt-1" Style="white-space: pre-wrap;">@_event.Description</MudText>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" md="4">
            <MudCard Class="pa-4">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">参加登録</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudAlert Severity="Severity.Info" Dense="true">
                        Registrations モジュール実装後に参加登録フォーム・参加者一覧を表示します。
                    </MudAlert>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private EventRegistration.Events.Application.EventDto? _event;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        _event = await EventsAppService.GetByIdAsync(Id);
        _loading = false;
    }
}
