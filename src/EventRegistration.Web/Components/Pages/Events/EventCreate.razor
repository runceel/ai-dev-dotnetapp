@page "/events/create"
@inject EventRegistration.Events.Application.UseCases.CreateEventUseCase CreateEvent
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>イベント作成</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">新しいイベントを作成</MudText>

<MudPaper Class="pa-4" MaxWidth="600px">
    <EditForm Model="_model" OnValidSubmit="HandleValidSubmit">
        <DataAnnotationsValidator />

        <MudTextField @bind-Value="_model.Name"
                      Label="イベント名"
                      Required="true"
                      RequiredError="イベント名は必須です"
                      For="@(() => _model.Name)"
                      Class="mb-3" />

        <MudDatePicker @bind-Date="_model.ScheduledDate"
                       Label="開催日"
                       Required="true"
                       RequiredError="開催日は必須です"
                       DateFormat="yyyy/MM/dd"
                       Class="mb-3" />

        <MudTimePicker @bind-Time="_model.ScheduledTime"
                       Label="開催時間"
                       Required="true"
                       RequiredError="開催時間は必須です"
                       Class="mb-3" />

        <MudNumericField @bind-Value="_model.Capacity"
                         Label="定員"
                         Required="true"
                         RequiredError="定員は必須です"
                         Min="1"
                         For="@(() => _model.Capacity)"
                         Class="mb-3" />

        <MudTextField @bind-Value="_model.Description"
                      Label="説明"
                      Lines="4"
                      For="@(() => _model.Description)"
                      Class="mb-3" />

        <div class="d-flex justify-end gap-2 mt-4">
            <MudButton Variant="Variant.Text"
                       Color="Color.Default"
                       Href="/events">
                キャンセル
            </MudButton>
            <MudButton ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       Disabled="_submitting">
                @if (_submitting)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                保存
            </MudButton>
        </div>
    </EditForm>
</MudPaper>

@code {
    private readonly CreateEventFormModel _model = new();
    private bool _submitting;

    private async Task HandleValidSubmit()
    {
        if (_model.ScheduledDate is null || _model.ScheduledTime is null || _model.Capacity is null)
        {
            return;
        }

        _submitting = true;
        try
        {
            var scheduledAt = new DateTimeOffset(
                _model.ScheduledDate.Value.Date + _model.ScheduledTime.Value,
                DateTimeOffset.Now.Offset);

            var eventId = await CreateEvent.ExecuteAsync(
                _model.Name,
                _model.Description,
                scheduledAt,
                _model.Capacity.Value);

            Snackbar.Add("イベントを作成しました。", Severity.Success);
            Navigation.NavigateTo($"/events/{eventId}");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"エラーが発生しました: {ex.Message}", Severity.Error);
        }
        finally
        {
            _submitting = false;
        }
    }

    private sealed class CreateEventFormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "イベント名は必須です")]
        public string Name { get; set; } = string.Empty;

        public string? Description { get; set; }

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "開催日は必須です")]
        public DateTime? ScheduledDate { get; set; }

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "開催時間は必須です")]
        public TimeSpan? ScheduledTime { get; set; }

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "定員は必須です")]
        [System.ComponentModel.DataAnnotations.Range(1, int.MaxValue, ErrorMessage = "定員は1以上で指定してください")]
        public int? Capacity { get; set; }
    }
}
